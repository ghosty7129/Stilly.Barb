# Server Configuration
PORT=5000
NODE_ENV=production
RATE_LIMIT_MAX=200
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.vercel.app

# Email Configuration
EMAIL_ENABLED=false
EMAIL_USER=noreply@barbershop-unusual.com
RESEND_API_KEY=your-resend-api-key

# Vercel Blob Storage (required for persistent reservations)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_read_write_token

# To enable emails, set EMAIL_ENABLED=true and set RESEND_API_KEY
# Resend dashboard: https://resend.com/api-keys
